'use client';
import { create } from 'zustand';
import { Process, TimelineBlock, Algorithm, AppStep, ScheduleResult } from '@/types';
import { computeSchedule, createProcess, resetPidCounter } from '@/utils/scheduling';
import { AlgorithmInputs } from '@/components/AlgorithmInputModal';
import { 
  initializeStepExecution, 
  executeStep, 
  isExecutionComplete,
  StepExecutionState 
} from '@/utils/stepExecution';

interface SimState {
  step: AppStep;
  processes: Process[];
  selectedAlgorithm: Algorithm | null;
  algorithmInputs: AlgorithmInputs;
  schedule: ScheduleResult | null;
  executionIndex: number;
  visibleBlocks: TimelineBlock[];
  isPlaying: boolean;
  isExplainMode: boolean;
  isRealTime: boolean;
  currentTime: number;
  contextSwitchTime: number;
  realTimeSpeed: number;
  
  // Step-by-step execution state
  stepState: StepExecutionState | null;
  isStepMode: boolean;

  goToStep: (step: AppStep) => void;
  addProcess: (overrides?: Partial<Process>) => void;
  removeProcess: (id: string) => void;
  updateProcess: (id: string, updates: Partial<Process>) => void;
  selectAlgorithm: (algo: Algorithm) => void;
  setAlgorithmInputs: (inputs: AlgorithmInputs) => void;
  startExecution: () => void;
  executeNextStep: () => void;
  advanceExecution: () => void;
  setPlaying: (val: boolean) => void;
  toggleExplainMode: () => void;
  resetSimulation: () => void;
  toggleRealTime: () => void;
  setRealTimeSpeed: (speed: number) => void;
  setContextSwitchTime: (time: number) => void;
}

export const useSimStore = create<SimState>((set, get) => ({
  step: 'landing',
  processes: [],
  selectedAlgorithm: null,
  algorithmInputs: {},
  schedule: null,
  executionIndex: 0,
  visibleBlocks: [],
  isPlaying: false,
  isExplainMode: true,
  isRealTime: false,
  currentTime: 0,
  contextSwitchTime: 1,
  realTimeSpeed: 1000,
  stepState: null,
  isStepMode: true,

  goToStep: (step) => set({ step }),

  addProcess: (overrides) => {
    const p = createProcess(overrides);
    set(state => ({ processes: [...state.processes, p] }));
  },

  removeProcess: (id) => {
    set(state => ({ processes: state.processes.filter(p => p.id !== id) }));
  },

  updateProcess: (id, updates) => {
    set(state => ({
      processes: state.processes.map(p =>
        p.id === id ? { ...p, ...updates, remainingTime: updates.burstTime ?? p.remainingTime } : p
      ),
    }));
  },

  selectAlgorithm: (algo) => set({ selectedAlgorithm: algo }),

  setAlgorithmInputs: (inputs) => set({ algorithmInputs: inputs }),

  startExecution: () => {
    const { processes, selectedAlgorithm, contextSwitchTime, algorithmInputs } = get();
    if (!selectedAlgorithm || processes.length === 0) return;
    
    // Apply priority overrides if provided
    const processesWithPriority = processes.map(p => {
      if (algorithmInputs.priorityValues && algorithmInputs.priorityValues[p.id] !== undefined) {
        return { ...p, priority: algorithmInputs.priorityValues[p.id] };
      }
      return p;
    });
    
    const quantum = algorithmInputs.quantum || 4;
    const schedule = computeSchedule(processesWithPriority, selectedAlgorithm, contextSwitchTime, quantum);
    
    // Initialize step-by-step execution state
    const stepState = initializeStepExecution(
      processesWithPriority,
      selectedAlgorithm,
      quantum
    );
    
    set({ 
      processes: processesWithPriority,
      schedule, 
      executionIndex: 0, 
      visibleBlocks: [], 
      currentTime: 0,
      stepState,
      isStepMode: true 
    });
  },

  executeNextStep: () => {
    const { stepState, selectedAlgorithm, processes } = get();
    if (!stepState || !selectedAlgorithm) return;

    // Check if execution is complete
    if (isExecutionComplete(stepState, processes.length)) {
      set({ step: 'complete', isPlaying: false });
      return;
    }

    // Execute next step
    const newState = executeStep(stepState, selectedAlgorithm);
    
    set({
      stepState: newState,
      visibleBlocks: newState.ganttBlocks,
      currentTime: newState.currentTime,
    });
    
    // Check again if complete after this step
    if (isExecutionComplete(newState, processes.length)) {
      setTimeout(() => set({ step: 'complete', isPlaying: false }), 800);
    }
  },

  advanceExecution: () => {
    // Delegate to executeNextStep for step mode
    get().executeNextStep();
  },

  setPlaying: (val) => set({ isPlaying: val }),

  toggleExplainMode: () => set(state => ({ isExplainMode: !state.isExplainMode })),

  resetSimulation: () => {
    resetPidCounter();
    set({
      step: 'create',
      processes: [],
      selectedAlgorithm: null,
      algorithmInputs: {},
      schedule: null,
      executionIndex: 0,
      visibleBlocks: [],
      isPlaying: false,
      currentTime: 0,
      isRealTime: false,
      stepState: null,
      isStepMode: true,
    });
  },

  toggleRealTime: () => set(state => ({ isRealTime: !state.isRealTime })),

  setRealTimeSpeed: (speed: number) => set({ realTimeSpeed: speed }),

  setContextSwitchTime: (time: number) => set({ contextSwitchTime: time }),
}));
